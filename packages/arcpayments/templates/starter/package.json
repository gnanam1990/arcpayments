{
  "name": "__APP_NAME__",
  "version": "0.1.0",
  "private": true,
  "description": "A metered MCP server + buyer agent on Arc testnet, scaffolded by arcpayments. Not affiliated with Circle/Arc.",
  "license": "MIT",
  "type": "module",
  "bin": {
