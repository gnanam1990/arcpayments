{
  "name": "arcpayments",
  "version": "0.8.0",
  "description": "Community toolkit for building on Arc (not affiliated with Circle/Arc) — a scaffolder + CLI + library for agentic commerce: wallets, x402 paywalls, Circle Gateway nanopayment batching, cross-chain withdrawal (CCTP), and a spend-guard safety kernel.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "arc",
    "circle",
    "usdc",
    "x402",
    "cctp",
    "mcp",
    "agentic-commerce",
    "nanopayments",
    "stablecoin",
    "cli",
    "scaffolder"
  ],
  "homepage": "https://github.com/gnanam1990/arcpayments#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gnanam1990/arcpayments.git",
    "directory": "packages/arcpayments"
  },
  "bugs": {
    "url": "https://github.com/gnanam1990/arcpayments/issues"
  },
  "bin": {
    "arcpayments": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist/**/*.js", "dist/**/*.d.ts", "templates", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "cd ../.. && bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "viem": "^2.54.1",
    "@circle-fin/x402-batching": "^3.2.0",
    "@x402/core": "^2.3.0",
    "@x402/evm": "^2.3.0",
    "@circle-fin/bridge-kit": "^1.11.1",
    "@circle-fin/adapter-viem-v2": "^1.12.1"
  },
  "engines": {
    "node": ">=20"
  }
}
