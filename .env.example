# ---- Arc network (verified values in NETWORK.md) ----
# TESTNET today. Leave BLANK to use the verified Arc testnet defaults baked into
# the `network` module. Switch to mainnet later by changing ONLY these values.
ARC_RPC_URL=            # default: https://rpc.testnet.arc.network
ARC_CHAIN_ID=           # default: 5042002
ARC_EXPLORER_URL=       # default: https://testnet.arcscan.app
# ARC_NETWORK_NAME=     # optional label, e.g. arc-testnet

# ---- Faucet (testnet USDC/EURC) ----
# Get test funds at https://faucet.circle.com  (no key needed; here for reference)
# ARC_FAUCET_URL=       # default: https://faucet.circle.com

# ---- Wallets (TESTNET ONLY — never commit real keys) ----
# Populated by `arcpayments wallet:new` (writes here only if this file is gitignored).
SELLER_PRIVATE_KEY=
BUYER_PRIVATE_KEY=
# metered-mcp payout identity: set SELLER_ADDRESS, or leave blank to derive it
# from SELLER_PRIVATE_KEY.
SELLER_ADDRESS=

# ---- x402 / Circle Gateway (paywall + settlement; verified in NETWORK.md) ----
# Leave BLANK to use the verified Arc testnet defaults from the `network` module.
# ARC_USDC_ADDRESS=         # default: 0x3600000000000000000000000000000000000000 (6 decimals)
# ARC_GATEWAY_URL=          # default: https://gateway-api-testnet.circle.com
# GatewayWallet = EIP-712 verifyingContract for Circle Gateway batched x402 (NOT USDC).
# ARC_GATEWAY_WALLET=       # default: 0x0077777d7EBA4688BDeF3E311b846F25870A19B9
# x402 signing domain (confirmed from Gateway /supported — Stage 4).
# ARC_X402_DOMAIN_NAME=     # default: GatewayWalletBatched
# ARC_X402_DOMAIN_VERSION=  # default: 1
# ARC_X402_MIN_VALIDITY_SECONDS=  # default: 604800 (7d; validBefore >= now + this)
# ARC_X402_VERSION=         # default: 2
# ARC_GATEWAY_CHAIN_NAME=   # default: arcTestnet (SDK chain id; 'arc' for mainnet)

# ---- Live settlement (local only; see docs/RUNBOOK-live-settlement.md) ----
# The buyer loop settles from the Gateway balance — deposit first:
#   arcpayments gateway:deposit <amount>       (needs BUYER_PRIVATE_KEY)
#   LIVE=1 bun run --filter metered-mcp live:settle
