# ---- Wallets (TESTNET ONLY — never commit real keys) ----
# Fill these with `npx arcpayments wallet:new` (writes here only if this file is gitignored).
SELLER_PRIVATE_KEY=
BUYER_PRIVATE_KEY=
# Payout identity: set SELLER_ADDRESS, or leave blank to derive it from SELLER_PRIVATE_KEY.
SELLER_ADDRESS=

# ---- Arc network ----
# Leave BLANK to use the verified Arc testnet defaults. Switch networks later by
# changing ONLY these values (see the arcpayments NETWORK reference).
ARC_RPC_URL=
ARC_CHAIN_ID=
ARC_EXPLORER_URL=

# ---- Safety guards (bound the autonomous buyer; all optional) ----
# Amounts are USDC decimals. An unset guard is simply disabled.
# ARC_GUARD_ALLOWLIST=            # comma-separated recipient addresses; ONLY these can be paid
# ARC_GUARD_BUDGET_CAP=          # e.g. 0.05  — cumulative spend ceiling (USDC)
# ARC_GUARD_PER_PAYMENT_MAX=     # e.g. 0.01  — max single payment (USDC)
# ARC_GUARD_HUMAN_GATE_THRESHOLD=# e.g. 0.02  — payments >= this need explicit human approval
# ARC_GUARD_RATE_MAX=            # e.g. 5     — max payments per window
# ARC_GUARD_RATE_WINDOW_MS=      # e.g. 60000 — the rate window in ms
